# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

target 'cashbook_app' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    require 'fileutils'
    
    # Set deployment target for all pods
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        build_config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
      end
    end

    # 定义需要禁用模块的 pod 名称列表
    pods_to_disable_module = [
      'react-native-device-info',
      'react-native-fs',
      'react-native-image-picker',
      'react-native-svg',
      'react-native-webview',
      # 可以添加其他有类似问题的 pod
    ]

    # 遍历所有 pod 目标，为特定 pod 设置 DEFINES_MODULE = NO 和 CLANG_ENABLE_MODULES = NO
    puts "=== 开始遍历所有 pod 目标 ==="
    installer.pods_project.targets.each do |target|
      pod_name = target.name
      puts "Pod 目标名称: #{pod_name}"
      
      # 检查目标名称是否在列表中
      # 处理 React Native 社区库的命名方式：通常目标名称会带有前缀，例如 'react-native-document-picker' 或 'RNReactNativeDocumentPicker'
      # 我们检查目标名称是否包含列表中的任何字符串
      should_disable = pods_to_disable_module.any? { |pod| pod_name.include?(pod) }

      if should_disable
        puts "✅ 找到并禁用: #{pod_name}"
        target.build_configurations.each do |build_config|
          build_config.build_settings['DEFINES_MODULE'] = 'NO'
          build_config.build_settings['CLANG_ENABLE_MODULES'] = 'NO'
          build_config.build_settings['MODULEMAP_FILE'] = ''
          puts "[Fix] Disabled module for pod: #{pod_name}"
        end
      else
        puts "  未匹配: #{pod_name}"
      end
    end
    puts "=== 结束遍历 pod 目标 ==="
    
    # 特别处理聚合目标（如 Pods-cashbook_app）
    puts "=== 开始处理聚合目标 ==="
    installer.pods_project.targets.each do |target|
      target_name = target.name
      # 检查是否是聚合目标：以 'Pods-' 开头
      if target_name.start_with?('Pods-')
        puts "找到聚合目标: #{target_name}"
        target.build_configurations.each do |build_config|
          # 禁用模块以避免 modulemap 问题
          build_config.build_settings['DEFINES_MODULE'] = 'NO'
          build_config.build_settings['CLANG_ENABLE_MODULES'] = 'NO'
          build_config.build_settings['MODULEMAP_FILE'] = ''
          puts "[Fix] 已为聚合目标 #{target_name} 禁用模块"
        end
      end
    end
    puts "=== 结束处理聚合目标 ==="
    
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end
