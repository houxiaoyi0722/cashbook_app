# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

target 'cashbook_app' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # Fix for Swift module map errors - create empty modulemaps for problematic pods
    pod_dir = File.join(__dir__, 'Pods')
    %w[react-native-document-picker ShareIntent].each do |pod_name|
      pod_path = File.join(pod_dir, pod_name)
      if Dir.exist?(pod_path)
        # Convert "react-native-document-picker" to "react_native_document_picker"
        module_name = pod_name.gsub('-', '_')
        modulemap_path = File.join(pod_path, "#{module_name}.modulemap")
        File.write(modulemap_path, "module #{module_name} { }\n")
      end
    end
    
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end
