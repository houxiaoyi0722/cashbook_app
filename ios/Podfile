# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

target 'cashbook_app' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # Fix for Swift module map errors - create empty modulemaps for problematic pods
    # This runs after all pods are installed and extracted
    pod_dir = File.join(__dir__, 'Pods')
    
    # Find all pod directories and ensure they have modulemaps
    if Dir.exist?(pod_dir)
      Dir.glob(File.join(pod_dir, '*')).each do |pod_path|
        next unless File.directory?(pod_path)
        pod_name = File.basename(pod_path)
        # Convert "react-native-document-picker" to "react_native_document_picker"
        module_name = pod_name.gsub(/[^a-zA-Z0-9_]/, '_')
        modulemap_path = File.join(pod_path, "#{module_name}.modulemap")
        umbrella_path = File.join(pod_path, "#{module_name}.umbrella.h")
        
        # Create modulemap if it doesn't exist
        unless File.exist?(modulemap_path)
          File.write(modulemap_path, "module #{module_name} { umbrella header \"#{module_name}.umbrella.h\" export * }\n")
        end
        
        # Create umbrella header if it doesn't exist
        unless File.exist?(umbrella_path)
          File.write(umbrella_path, "// Umbrella header for #{pod_name}\n#ifndef #{module_name.upcase}_UMBRELLA_H\n#define #{module_name.upcase}_UMBRELLA_H\n#endif\n")
        end
      end
    end
    
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end
